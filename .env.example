# Frontend API base URL used by Vite in local development.
VITE_RENDER_SERVER=http://127.0.0.1:3001

# Backend listener and browser origin settings.
PORT=3001
NODE_ENV=development
ADMIN_ALLOWED_ORIGINS=http://127.0.0.1:3010

# Optional purchase entry shown in the top workbench header.
# Override the default public shop entry when needed.
VITE_SHOP_URL=https://pay.ldxp.cn/shop/FTIWLFHQ
VITE_SHOP_LINK_LABEL=选购服务

# Set a long random value before enabling production admin sessions.
ADMIN_AUTH_SECRET=
ADMIN_AUTH_DISABLED=true
ADMIN_COOKIE_SAMESITE=lax

# Runtime data and asset locations. Empty values use project defaults.
FDESIGN_DATA_DIR=
FDESIGN_OUTPUT_DIR=
FONT_ASSETS_DIR=

# Cleanup and startup backup switches.
DISABLE_SCHEDULED_CLEANUP=false
DISABLE_SCHEDULED_EXPORT_ARTIFACTS_CLEANUP=false
DISABLE_SCHEDULED_CUTOUT_NO_PSD_CLEANUP=false
DISABLE_SCHEDULED_TEMPLATE_IMAGES_CLEANUP=false
FDESIGN_BACKUP_ON_START=true
FDESIGN_BACKUP_KEEP=3
FDESIGN_BACKUP_DIR=
FDESIGN_BACKUP_FALLBACK_DIR=

# Photoshop export worker controls.
PS_RESIDENT_MODE=true
PS_RESIDENT_IDLE_EXIT_MS=300000
PS_EXPORT_CONCURRENCY=1
PS_EXPORT_MAX_RETRIES=0
PS_EXPORT_RETRY_BASE_MS=1200
PS_EXPORT_RETRY_MAX_MS=12000
PS_BRING_TO_FRONT=false
KEEP_EXPORT_TEMP_FILES=false
